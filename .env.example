# Provider keys for live pipeline runs.
RUNDOWN_API_KEY=
ODDS_API_KEY=
PROPLINE_API_KEY=

# Optional Supabase sidecar database.
# For hosted Supabase, use the project URL and service-role key.
# For local Supabase CLI, the URL is usually http://127.0.0.1:54321.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional Netlify functions / push notifications.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
NOTIFY_SECRET=
NETLIFY_SITE_URL=http://127.0.0.1:8888

# Optional manual pipeline trigger function.
GITHUB_PAT=
GITHUB_REPO=treidjbi/BaseballbettingEdge
GITHUB_WORKFLOW=pipeline.yml
